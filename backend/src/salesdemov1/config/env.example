# Copy to .env inside salesdemov1/ or set in shell.
# Points at the same Postgres as the main app (only touch is_demo rows).

DATABASE_URL=postgresql://postgres:password@localhost:5432/viptaksi_demo

# Required for seed / reset / ensureDemoReady / runSeed
ALLOW_DEMO=true

# DATABASE_URL must contain "demo" or "staging" unless:
# DEMO_RELAX_DB_URL=true

# Log-only: no DELETE/INSERT (still runs counts + advisory lock)
# DEMO_DRY_RUN=true
