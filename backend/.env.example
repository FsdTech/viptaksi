# Copy values for local development; use strong secrets in production.
PORT=
NODE_ENV=

# PostgreSQL
DATABASE_URL=
# Or use discrete vars (DATABASE_URL takes precedence in config if set):
# PGHOST=localhost
# PGPORT=5432
# PGUSER=postgres
# PGPASSWORD=postgres
# PGDATABASE=viptaksi

JWT_SECRET=
JWT_EXPIRES_IN=

# Comma-separated origins for CORS + Socket.IO (admin Vite default shown)
CORS_ORIGIN=
OPENAI_BASE_URL=
